.decl op(e:number, y: symbol)
.input op

//x is visible to y
.decl vis(x:number, y:number)
.input vis

.decl state(x: number)
.output state

.decl visible(e:number, p: number)

visible(e,p) :- vis(e,p).
visible(e,p) :- visible(e,y), vis(y,p).

state(x) :- x = count : { op(_, "increment") } . //- count : { op(_, "decrement") }.